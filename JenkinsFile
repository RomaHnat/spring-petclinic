pipeline {
    agent any

    environment {
        DOCKER_IMAGE = "romanhnat/petclinic:latest"
        TERRAFORM_DIR = "."
        TERRAFORM_VERSION = '1.7.5'
        ANSIBLE_DIR = "."
        MAVEN_CMD = './mvnw'
        SONAR_TOKEN = credentials('sonarqube-token')
        PROJECT_KEY = 'spring-petclinic'
        AWS_CREDENTIALS_ID = 'aws-terraform-creds'
        EC2_USER = "ec2-user"
        EC2_HOST = ""
    }

    stages {

        stage('Clean Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout Source Code') {
            steps {
                git branch: 'main', url: 'https://github.com/RomaHnat/spring-petclinic.git'
            }
        }

        stage('Compile Application') {
            steps {
                sh 'rm -rf .terraform .bin || true'
                sh 'chmod +x mvnw'
                sh '${MAVEN_CMD} clean compile'
            }
        }

        stage('Run Unit Tests') {
            steps {
                sh '${MAVEN_CMD} test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQubeLocal') {
                    sh '${MAVEN_CMD} sonar:sonar -Dsonar.projectKey=${PROJECT_KEY} -Dsonar.login=${SONAR_TOKEN}'
                }
            }
        }

        stage('Sonar Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Setup Terraform CLI') {
            steps {
                script {
                    env.TERRAFORM_CMD = sh(
                        script: '''
                            if command -v terraform >/dev/null 2>&1; then
                                command -v terraform
                                exit 0
                            fi

                            mkdir -p "$WORKSPACE/.bin"

                            if [ ! -x "$WORKSPACE/.bin/terraform" ]; then
                                cd "$WORKSPACE/.bin"
                                rm -f terraform terraform.zip
                                TERRAFORM_URL="https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip"

                                if command -v curl >/dev/null 2>&1; then
                                    curl -fsSL -o terraform.zip "$TERRAFORM_URL"
                                elif command -v wget >/dev/null 2>&1; then
                                    wget -qO terraform.zip "$TERRAFORM_URL"
                                else
                                    echo "Neither curl nor wget is available on Jenkins agent"
                                    exit 1
                                fi

                                jar xf terraform.zip
                                chmod +x terraform
                                rm -f terraform.zip
                            fi

                            echo "$WORKSPACE/.bin/terraform"
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "Using Terraform binary: ${env.TERRAFORM_CMD}"
                }
            }
        }

        stage('Setup Ansible CLI') {
            steps {
                script {
                    env.ANSIBLE_CMD = sh(
                        script: '''
                            if command -v ansible-playbook >/dev/null 2>&1; then
                                command -v ansible-playbook
                                exit 0
                            fi

                            mkdir -p "$WORKSPACE/.bin"

                            if command -v pip3 >/dev/null 2>&1; then
                                pip3 install --user ansible >/dev/null 2>&1
                            elif command -v pip >/dev/null 2>&1; then
                                pip install --user ansible >/dev/null 2>&1
                            else
                                echo "Neither pip3 nor pip is available on Jenkins agent"
                                exit 1
                            fi

                            if [ -x "$HOME/.local/bin/ansible-playbook" ]; then
                                echo "$HOME/.local/bin/ansible-playbook"
                            elif [ -x "$WORKSPACE/.local/bin/ansible-playbook" ]; then
                                echo "$WORKSPACE/.local/bin/ansible-playbook"
                            else
                                echo "ansible-playbook was not found after installation"
                                exit 1
                            fi
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "Using Ansible binary: ${env.ANSIBLE_CMD}"
                }
            }
        }

        stage('Setup Docker CLI') {
            steps {
                script {
                    env.DOCKER_CMD = sh(
                        script: '''
                            if command -v docker >/dev/null 2>&1; then
                                command -v docker
                                exit 0
                            fi

                            mkdir -p "$WORKSPACE/.bin"

                            if [ ! -x "$WORKSPACE/.bin/docker" ]; then
                                cd "$WORKSPACE/.bin"
                                rm -rf docker docker.tgz

                                ARCH="$(uname -m)"
                                if [ "$ARCH" = "x86_64" ] || [ "$ARCH" = "amd64" ]; then
                                    DOCKER_TGZ_URL="https://download.docker.com/linux/static/stable/x86_64/docker-27.3.1.tgz"
                                elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
                                    DOCKER_TGZ_URL="https://download.docker.com/linux/static/stable/aarch64/docker-27.3.1.tgz"
                                else
                                    echo "Unsupported architecture for Docker CLI bootstrap: $ARCH"
                                    exit 1
                                fi

                                if command -v curl >/dev/null 2>&1; then
                                    curl -fsSL -o docker.tgz "$DOCKER_TGZ_URL"
                                elif command -v wget >/dev/null 2>&1; then
                                    wget -qO docker.tgz "$DOCKER_TGZ_URL"
                                else
                                    echo "Neither curl nor wget is available on Jenkins agent"
                                    exit 1
                                fi

                                tar -xzf docker.tgz --strip-components=1 docker/docker
                                chmod +x ./docker
                                rm -f docker.tgz
                            fi

                            echo "$WORKSPACE/.bin/docker"
                        ''',
                        returnStdout: true
                    ).trim()

                    echo "Using Docker binary: ${env.DOCKER_CMD}"
                    sh '${DOCKER_CMD} version'
                }
            }
        }

        stage('Provision Infrastructure (Terraform)') {
            steps {
                echo 'Starting Terraform provision stage'
                sh 'test -n "${TERRAFORM_CMD}" || (echo "TERRAFORM_CMD is empty" && exit 1)'
                withCredentials([usernamePassword(
                    credentialsId: "${AWS_CREDENTIALS_ID}",
                    usernameVariable: 'AWS_ACCESS_KEY_ID',
                    passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                )]) {
                    sh 'test -n "$AWS_ACCESS_KEY_ID" || (echo "AWS_ACCESS_KEY_ID is empty" && exit 1)'
                    sh 'test -n "$AWS_SECRET_ACCESS_KEY" || (echo "AWS_SECRET_ACCESS_KEY is empty" && exit 1)'
                    dir("${TERRAFORM_DIR}") {
                        sh '${TERRAFORM_CMD} version'
                        sh 'AWS_EC2_METADATA_DISABLED=true ${TERRAFORM_CMD} init'
                        sh 'AWS_EC2_METADATA_DISABLED=true ${TERRAFORM_CMD} apply -auto-approve'
                        script {
                            def ip = sh(
                                script: "AWS_EC2_METADATA_DISABLED=true ${env.TERRAFORM_CMD} output -raw public_ip",
                                returnStdout: true
                            ).trim()
                            if (!ip) {
                                error("terraform output returned empty IP. Check S3 backend and apply logs.")
                            }
                            env.EC2_HOST = ip
                            echo "EC2 Public IP: ${env.EC2_HOST}"
                        }
                    }
                }
            }
        }

        stage('Confirm EC2 IP') {
            steps {
                script {
                    if (!env.EC2_HOST) {
                        error("EC2_HOST is empty — terraform output did not set the IP. Check Provision stage logs.")
                    }
                    echo "Confirmed EC2 IP: ${env.EC2_HOST}"
                }
            }
        }

        stage('Configure EC2 (Ansible)') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    dir("${ANSIBLE_DIR}") {
                        sh """
                        echo "[web]" > inventory.ini
                        echo "${env.EC2_HOST} ansible_user=${EC2_USER} ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'" >> inventory.ini
                        ANSIBLE_HOST_KEY_CHECKING=False ${ANSIBLE_CMD} -i inventory.ini playbook.yml
                        """
                    }
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '${DOCKER_CMD} build -t $DOCKER_IMAGE .'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo $DOCKER_PASS | ${DOCKER_CMD} login -u $DOCKER_USER --password-stdin'
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '${DOCKER_CMD} push $DOCKER_IMAGE'
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh '''
                    ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null ${EC2_USER}@${EC2_HOST} "docker rm -f petclinic || true; occupied=\\$(docker ps --filter 'publish=8080' -q); if [ -n \\\"\\$occupied\\\" ]; then docker rm -f \\$occupied || true; fi; docker pull ${DOCKER_IMAGE}; docker run -d --name petclinic --restart unless-stopped -p 8080:8080 ${DOCKER_IMAGE}"
                    '''
                }
            }
        }

        stage('Smoke Test Deployment') {
            steps {
                sh '''
                APP_URL="http://${EC2_HOST}:8080"
                echo "Checking ${APP_URL}"
                if command -v curl >/dev/null 2>&1; then
                    for i in 1 2 3 4 5; do
                        curl -fsS --max-time 10 "$APP_URL" >/dev/null && exit 0
                        echo "Attempt $i failed, retrying..."
                        sleep 8
                    done
                elif command -v wget >/dev/null 2>&1; then
                    for i in 1 2 3 4 5; do
                        wget -q --spider --timeout=10 "$APP_URL" && exit 0
                        echo "Attempt $i failed, retrying..."
                        sleep 8
                    done
                else
                    echo "Neither curl nor wget is available for smoke test"
                    exit 1
                fi
                echo "Smoke test failed for ${APP_URL}"
                exit 1
                '''
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Full CI/CD Pipeline Executed Successfully!"
        }
        failure {
            echo "Pipeline Failed. Check Logs."
        }
    }
}